# =============================================================================
# API SENTINEL — Root .gitignore
# Covers: .NET (C#) backend + TypeScript / Next.js frontend
# =============================================================================

# -----------------------------------------------------------------------------
# .NET / C#
# -----------------------------------------------------------------------------

# Build output
[Bb]in/
[Oo]bj/

# NuGet packages
*.nupkg
*.snupkg
project.lock.json
project.nuget.cache
packages/
*.nuget.props
*.nuget.targets

# Restore cache
.nuget/

# App settings (may contain secrets / connection strings)
appsettings.json
appsettings.*.json

# MSBuild
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Visual Studio / Rider
.vs/
.idea/
*.VC.db
*.VC.VC.opendb

# Publish output
[Pp]ublish/
[Pp]ublish[Oo]utput/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Runtime
*.runtimeconfig.json
*.staticwebassets.endpoints.json

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage*/

# Crash dumps
*.mdmp
*.dmp

# ReSharper
_ReSharper*/

# DocProject
doc/
doc_project/

# Entity Framework migrations (keep Migrations/ source, ignore snapshots if desired)
# Uncomment below if you want to ignore EF snapshots:
# **/Migrations/*Snapshot.cs

# -----------------------------------------------------------------------------
# TypeScript / Node.js / Next.js
# -----------------------------------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build output
.next/
out/
dist/
build/
.cache/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Next.js
next-env.d.ts

# TypeScript build info
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
logs/
*.log

# Testing
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# Storybook
storybook-static/

# Turbopack / Turborepo
.turbo/

# Vercel
.vercel/

# Misc
.DS_Store
Thumbs.db
*.pem

# Editor directories
.vscode/
*.swp
*.swo
*~
